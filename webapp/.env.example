# Copie este arquivo para .env.local (uso local) e preencha os valores.
# No Render, essas mesmas variáveis são cadastradas na aba "Environment" do serviço.

# --- Turso (banco de dados) ---
# Encontre esses dois valores no dashboard do Turso, dentro do seu banco de dados.
TURSO_DATABASE_URL=libsql://SEU-BANCO.turso.io
TURSO_AUTH_TOKEN=cole-aqui-o-token-gerado-no-turso

# --- Login do sistema ---
# Usuário e senha que protegem o site inteiro. Troque para valores próprios.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=troque-esta-senha

# --- Segurança da sessão de login ---
# Qualquer texto longo e aleatório. Gere um novo e não compartilhe.
# Ex.: abra https://www.uuidgenerator.net/ e cole o valor gerado aqui.
SESSION_SECRET=troque-por-um-texto-aleatorio-e-longo
